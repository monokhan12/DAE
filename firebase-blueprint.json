{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "student", "employer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "JobListing": {
      "title": "Job Listing",
      "description": "A job opening posted on the platform",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "postedDate": { "type": "string" },
        "type": { "type": "string", "enum": ["Full-time", "Part-time", "Contract", "Internship"] },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "salary": { "type": "string" },
        "link": { "type": "string", "format": "uri" },
        "logo": { "type": "string", "format": "uri" },
        "authorUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "company", "location", "description", "type", "authorUid"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An article or update",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string", "format": "uri" },
        "authorUid": { "type": "string" }
      },
      "required": ["title", "excerpt", "category", "authorUid"]
    },
    "Course": {
      "title": "Course",
      "description": "An educational course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "instructor": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "level": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "rating": { "type": "number" },
        "enrolledCount": { "type": "number" },
        "lessons": { "type": "array", "items": { "$ref": "#/definitions/Lesson" } }
      },
      "required": ["title", "description", "instructor", "category"]
    },
    "Roadmap": {
      "title": "Roadmap",
      "description": "AI generated career roadmap",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "extractedSkills": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "summary", "createdAt"]
    },
    "NewsletterSubscription": {
      "title": "Newsletter Subscription",
      "description": "User email for newsletter subscription",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/jobs/{jobId}": {
      "schema": "JobListing",
      "description": "Job listings collection"
    },
    "/posts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog posts collection"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Educational courses collection"
    },
    "/roadmaps/{roadmapId}": {
      "schema": "Roadmap",
      "description": "User career roadmaps collection"
    },
    "/subscriptions/{email}": {
      "schema": "NewsletterSubscription",
      "description": "Newsletter subscriptions collection"
    }
  }
}
